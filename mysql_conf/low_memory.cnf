[mysqld]
# =========================================================
# MySQL Low-Memory Configuration
# Target: 2GB RAM Server (API Absensi)
# Total MySQL target RAM: ~250-300MB
# =========================================================

# ─── InnoDB Buffer Pool (paling penting!) ─────────────────
# Default: 128MB. Untuk 2GB server, batasi lebih kecil.
innodb_buffer_pool_size        = 128M
innodb_buffer_pool_instances   = 1

# ─── Reduce temp table memory ─────────────────────────────
tmp_table_size                 = 16M
max_heap_table_size            = 16M

# ─── Query cache & connection limits ──────────────────────
max_connections                = 20
thread_stack                   = 128K
thread_cache_size              = 4

# ─── InnoDB Tuning ────────────────────────────────────────
innodb_log_buffer_size         = 4M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method            = O_DIRECT

# ─── Disable unused features ──────────────────────────────
performance_schema             = OFF
skip-name-resolve
