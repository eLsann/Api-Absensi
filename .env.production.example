# ==============================================================
# ABSENSI API — PRODUCTION ENVIRONMENT EXAMPLE
# ==============================================================
# Cara pakai:
#   cp .env.production.example .env
# Lalu isi semua nilai yang bertanda: CHANGE_THIS
# ==============================================================
# ⚠️ File .env TIDAK BOLEH di-commit ke Git!
# ⚠️ File ini (.env.production.example) AMAN di-commit.
# ==============================================================

# ─── Application ──────────────────────────────────────────────
APP_NAME=Absensi API
ENV=production

# ─── Docker Image (diisi otomatis oleh CI/CD pipeline) ────────
# Format: owner/repo-name (semua huruf kecil, sesuai ghcr.io)
GITHUB_REPOSITORY=elsann/api-absensi
IMAGE_TAG=latest

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://absensi_user:CHANGE_THIS_DB_PASS@db:3306/absensi
DB_USER=absensi_user
DB_PASSWORD=CHANGE_THIS_DB_PASS
DB_NAME=absensi
DB_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASS

# ─── Security ─────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_RUN_COMMAND_ABOVE_TO_GENERATE
ADMIN_TOKEN_EXPIRE_HOURS=8

# ─── Admin Default ────────────────────────────────────────────
# ⚠️ Wajib ganti sebelum deploy pertama!
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ─── Device Authentication ────────────────────────────────────
# Format: device_id:token,device_id2:token2
DEVICE_TOKENS=kamera_01:CHANGE_THIS_TOKEN

# ─── CORS ─────────────────────────────────────────────────────
# Contoh: http://192.168.1.50:3000,https://dashboard.kantor.com
ALLOWED_ORIGINS=http://localhost:3000

# ─── Face Recognition ─────────────────────────────────────────
MAX_DISTANCE=0.85
MIN_FACE_PX=80
DETECTION_CONFIDENCE=0.9
# Confidence minimum MTCNN detection (0.0-1.0). Kurangi jika kamera jauh/buram

# ─── Attendance ───────────────────────────────────────────────
COOLDOWN_SECONDS=45

# ─── Snapshots ────────────────────────────────────────────────
SAVE_SNAPSHOTS=true
SNAPSHOT_DIR=./data/snapshots
SNAPSHOT_ON_UNKNOWN=true
SNAPSHOT_ON_LOW_CONF=true
LOW_CONF_DISTANCE=0.85

# ─── Timezone ─────────────────────────────────────────────────
TZ=Asia/Jakarta

# ─── Performance (2GB RAM: wajib 1 worker!) ───────────────────
WORKERS=1
DB_MAX_RETRIES=30
DB_RETRY_INTERVAL=2
APP_VERSION=2.0.0
